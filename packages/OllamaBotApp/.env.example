# OllamaBotApp example configuration
# No secrets belong in this file.

PORT=11435
OLLAMA_TARGETS=http://localhost:11434,http://localhost:11436
OLLAMA_EMBEDDING_TARGET=http://127.0.0.1:11437
PROXY_TIMEOUT_MS=300000
OLLAMABOT_LOCAL_CONCURRENCY=2
OLLAMABOT_CLOUD_CONCURRENCY=1
OLLAMABOT_EMBEDDING_CONCURRENCY=1
OLLAMABOT_MAX_ATTEMPTS=2
OLLAMABOT_RETRY_BACKOFF_BASE_MS=1200
OLLAMABOT_IDEMPOTENCY_TTL_MS=45000

