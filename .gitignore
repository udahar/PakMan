packages/**/.venv/
packages/**/env/

# Package runtime data / logs
packages/safety_sentry/logs/
packages/StockAI/data/

# packages/ is the SOURCE registry — commit it fully.
# Install location is ~/.pakman/ on user machines, NOT this directory.
# Only exclude build artifacts within package dirs.
packages/**/__pycache__/
packages/**/*.py[cod]
packages/**/*.egg-info/
packages/**/dist/
packages/**/build/

# Env
.env
.env.*
!.env.example

